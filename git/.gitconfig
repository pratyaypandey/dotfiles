[user]
	email = pratyayrakesh@gmail.com
	name = Pratyay Pandey
	signingkey = /Users/pratyay/.ssh/id_ed25519.pub
[gpg]
	format = ssh
[commit]
	gpgsign = true
[core]
	pager = delta
	excludesFile = ~/.config/git/ignore
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
[merge]
	conflictStyle = zdiff3
[init]
	defaultBranch = main
[fetch]
	prune = true
[push]
	autoSetupRemote = true
[pull]
	rebase = true
[rebase]
	autoStash = true
[rerere]
	enabled = true
